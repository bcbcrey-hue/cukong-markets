# =============================
# Minimum local runtime (wajib untuk start lokal)
# =============================
NODE_ENV=development
APP_NAME=cukong-markets
PUBLIC_BASE_URL=http://localhost:3000
APP_PORT=3000
APP_BIND_HOST=0.0.0.0

TELEGRAM_BOT_TOKEN=isi_token_bot_telegram
TELEGRAM_ALLOWED_USER_IDS=123456789
LOG_LEVEL=info

DATA_DIR=./data
LOG_DIR=./logs
TEMP_DIR=./tmp

# Callback route ini dikunci di source, jangan diubah.
INDODAX_CALLBACK_PATH=/indodax/callback
INDODAX_ENABLE_CALLBACK_SERVER=false

# =============================
# Production wajib (routing + callback security)
# =============================
# Untuk NODE_ENV=production:
# - PUBLIC_BASE_URL, APP_PORT, APP_BIND_HOST wajib terisi.
# - Jika INDODAX_ENABLE_CALLBACK_SERVER=true:
#   * INDODAX_CALLBACK_PORT / INDODAX_CALLBACK_BIND_HOST / INDODAX_CALLBACK_ALLOWED_HOST wajib.
#   * INDODAX_CALLBACK_AUTH_MODE wajib "required".
#   * INDODAX_CALLBACK_SIGNATURE_SECRET wajib strong secret non-default.
INDODAX_CALLBACK_PORT=3001
INDODAX_CALLBACK_BIND_HOST=0.0.0.0
INDODAX_CALLBACK_ALLOWED_HOST=example.com
INDODAX_CALLBACK_AUTH_MODE=required
INDODAX_CALLBACK_SIGNATURE_SECRET=ganti_dengan_secret_acak_panjang
INDODAX_CALLBACK_SIGNATURE_HEADER=x-indodax-signature
INDODAX_CALLBACK_TIMESTAMP_HEADER=x-indodax-timestamp
INDODAX_CALLBACK_NONCE_HEADER=x-indodax-nonce
INDODAX_CALLBACK_REPLAY_WINDOW_MS=300000
INDODAX_CALLBACK_MAX_SKEW_MS=60000

# =============================
# Integrasi exchange + tuning opsional
# =============================
INDODAX_PUBLIC_BASE_URL=https://indodax.com/api
INDODAX_PRIVATE_BASE_URL=https://indodax.com/tapi
INDODAX_TRADE_API_V2_BASE_URL=https://tapi.indodax.com
INDODAX_HISTORY_MODE=v2_only
INDODAX_TIMEOUT_MS=15000
INDODAX_PUBLIC_MIN_INTERVAL_MS=250
INDODAX_PRIVATE_MIN_INTERVAL_MS=300
INDODAX_PRIVATE_LIVE_MIN_INTERVAL_MS=300
INDODAX_PRIVATE_RECONCILE_MIN_INTERVAL_MS=350
INDODAX_PRIVATE_BACKGROUND_MIN_INTERVAL_MS=450

POLLING_INTERVAL_MS=5000
MARKET_WATCH_INTERVAL_MS=4000
HOTLIST_LIMIT=15
MAX_PAIRS_TRACKED=250

DISCOVERY_ANOMALY_SLOTS=8
DISCOVERY_ROTATION_SLOTS=2
DISCOVERY_STEALTH_SLOTS=6
DISCOVERY_LIQUID_LEADER_SLOTS=1
DISCOVERY_MIN_VOLUME_IDR=15000000
DISCOVERY_MAX_SPREAD_PCT=3
DISCOVERY_MIN_DEPTH_SCORE=4
DISCOVERY_MAJOR_PAIR_MAX_SHARE=0.12

DEFAULT_TRADING_MODE=ALERT_ONLY
DEFAULT_QUOTE_ASSET=idr

RISK_MAX_OPEN_POSITIONS=3
RISK_MAX_POSITION_SIZE_IDR=100000
RISK_MAX_PAIR_SPREAD_PCT=1.25
RISK_COOLDOWN_MS=900000
PORTFOLIO_BASE_ENTRY_CAPITAL_IDR=100000
PORTFOLIO_MAX_TOTAL_DEPLOYED_CAPITAL_IDR=400000
PORTFOLIO_RISK_BUDGET_PER_POSITION_PCT=0.35
PORTFOLIO_MAX_EXPOSURE_MAJOR_PCT=0.60
PORTFOLIO_MAX_EXPOSURE_MID_PCT=0.50
PORTFOLIO_MAX_EXPOSURE_MICRO_PCT=0.45
PORTFOLIO_MAX_EXPOSURE_ANOMALY_PCT=0.50
PORTFOLIO_MAX_EXPOSURE_ROTATION_PCT=0.35
PORTFOLIO_MAX_EXPOSURE_STEALTH_PCT=0.40
PORTFOLIO_MAX_EXPOSURE_LIQUID_LEADER_PCT=0.30
PORTFOLIO_THIN_BOOK_DEPTH_SCORE_THRESHOLD=28
PORTFOLIO_THIN_BOOK_CAP_MULTIPLIER=0.55

WORKER_ENABLED=true
WORKER_POOL_SIZE=2

SCANNER_HISTORY_LIMIT=300
ORDERBOOK_DEPTH_LEVELS=20
TRADE_CLUSTER_WINDOW_MS=15000

PROBABILITY_THRESHOLD_AUTO=0.72
CONFIDENCE_THRESHOLD_AUTO=0.68
SPOOF_RISK_BLOCK_THRESHOLD=0.55
BUY_SLIPPAGE_BPS=60
MAX_BUY_SLIPPAGE_BPS=150
BUY_ORDER_TIMEOUT_MS=8000
