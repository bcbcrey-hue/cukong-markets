{
  "name": "cukong-markets",
  "version": "1.0.0",
  "private": true,
  "description": "Cukong-Markets TypeScript backend for Indodax market operations via Telegram",
  "main": "dist/bootstrap.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/bootstrap.ts",
    "render:nginx": "node scripts/render-nginx-conf.mjs",
    "start": "node dist/bootstrap.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck:probes": "tsc -p tsconfig.probes.json --noEmit",
    "test:probes": "npm run build && node scripts/run-probes.mjs",
    "probe:shadow-live": "tsx tests/real_exchange_shadow_run_probe.ts",
    "verify:shadow-live": "RUN_REAL_EXCHANGE_SHADOW=1 npm run probe:shadow-live",
    "verify": "npm run lint && npm run typecheck:probes && npm run test:probes",
    "install:immutable": "npm ci",
    "probe:audit": "node scripts/run-probes.mjs --audit",
    "probe:list": "node scripts/run-probes.mjs --list",
    "runtime:contract": "node --import tsx scripts/runtime-verifier-contract.mjs",
    "validate:batch-b:phase1": "node --import tsx scripts/run-batch-b-phase1-validation.mjs",
    "validate:batch-b:phase2": "node --import tsx scripts/run-batch-b-phase2-shadow-calibration.mjs",
    "validate:phase3": "tsx tests/phase3_market_real_validation_probe.ts",
    "validate:phase3:shadow-proof": "RUN_PHASE3_MODE=shadow-proof tsx tests/phase3_market_real_validation_probe.ts",
    "validate:phase3:market-real-check": "RUN_PHASE3_MODE=market-real-check tsx tests/phase3_market_real_validation_probe.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "dotenv": "^16.4.7",
    "pino": "^9.6.0",
    "telegraf": "^4.16.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "packageManager": "npm@11.4.2"
}
